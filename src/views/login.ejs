<div class="auth-wrap">
  <div class="card auth-card">
    <a class="brand" href="/"><span class="brand-mark">하</span> 하루예약</a>
    <h1 class="auth-title vp-text" data-from="'wght' 600" data-to="'wght' 900" data-radius="90" data-falloff="gaussian">로그인</h1>
    <p class="auth-desc">계정으로 로그인하고 예약을 시작하세요.</p>

    <% if (error) { %>
    <div class="alert alert--error" style="margin-bottom:18px">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/login" method="POST" class="form">
      <div class="field">
        <label for="username">아이디</label>
        <input class="input" type="text" id="username" name="username" autocomplete="username" placeholder="아이디 입력" required />
      </div>
      <div class="field">
        <label for="password">비밀번호</label>
        <input class="input" type="password" id="password" name="password" autocomplete="current-password" placeholder="비밀번호 입력" required />
      </div>
      <button type="submit" class="btn btn--primary btn--block btn--lg">로그인</button>
    </form>

    <p class="auth-foot">아직 계정이 없으신가요? <a href="/register">회원가입</a></p>
  </div>
</div>
