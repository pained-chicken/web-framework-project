<%
  var isEdit = !!facility;
  var f = facility || {
    name: "", category: "study", description: "",
    capacity: "", openTime: "09:00", closeTime: "22:00", isActive: true,
  };
  var cats = [
    { v: "study", l: "스터디룸" },
    { v: "meeting", l: "회의실" },
    { v: "sports", l: "체육시설" },
    { v: "etc", l: "기타" },
  ];
  var action = isEdit ? ("/admin/facilities/" + f._id) : "/admin/facilities";
%>
<header class="admin-topbar">
  <div>
    <div class="crumb"><a class="text-link" href="/admin/facilities">시설 관리</a> / <%= isEdit ? "수정" : "추가" %></div>
    <h1><%= isEdit ? "시설 수정" : "시설 추가" %></h1>
  </div>
</header>

<main class="admin-content" style="max-width:680px">
  <div class="card" style="padding:28px">
    <form action="<%= action %>" method="POST" class="form">
      <% if (isEdit) { %>
      <input type="hidden" name="_method" value="PUT" />
      <% } %>

      <div class="field">
        <label for="name">시설 이름<span class="req">*</span></label>
        <input class="input" type="text" id="name" name="name" value="<%= f.name %>" placeholder="예: 중앙도서관 스터디룸 A" required />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="category">카테고리<span class="req">*</span></label>
          <select class="select" id="category" name="category" required>
            <% cats.forEach(function (c) { %>
            <option value="<%= c.v %>" <%= f.category === c.v ? "selected" : "" %>><%= c.l %></option>
            <% }); %>
          </select>
        </div>
        <div class="field">
          <label for="capacity">정원<span class="req">*</span></label>
          <input class="input" type="number" id="capacity" name="capacity" value="<%= f.capacity %>" min="1" placeholder="명" required />
        </div>
      </div>

      <div class="field">
        <label for="description">설명</label>
        <textarea class="textarea" id="description" name="description" placeholder="시설에 대한 안내를 입력하세요."><%= f.description %></textarea>
      </div>

      <div class="field-row">
        <div class="field">
          <label for="openTime">운영 시작<span class="req">*</span></label>
          <input class="input" type="time" id="openTime" name="openTime" value="<%= f.openTime %>" required />
        </div>
        <div class="field">
          <label for="closeTime">운영 종료<span class="req">*</span></label>
          <input class="input" type="time" id="closeTime" name="closeTime" value="<%= f.closeTime %>" required />
        </div>
      </div>

      <div class="field">
        <label class="label">상태</label>
        <div class="checkbox-row">
          <input type="checkbox" id="isActive" name="isActive" value="true" <%= f.isActive ? "checked" : "" %> />
          <label for="isActive">활성 (사용자에게 노출 및 예약 허용)</label>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn--primary btn--lg">저장</button>
        <a class="btn btn--ghost btn--lg" href="/admin/facilities">취소</a>
      </div>
    </form>
  </div>
</main>
